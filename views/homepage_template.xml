<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="medisite_homepage" name="MediSite Clinic Homepage">
        <html>
        <head>
            <meta charset="UTF-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
            <title>MediSite Clinic &amp; Pharmacy | Hospital Management System</title>
            <meta name="description" content="MediSite Clinic - Complete Hospital Pharmacy Management System."/>
            <link rel="stylesheet" href="/medisite_clinic/static/src/css/homepage.css"/>
        </head>
        <body class="medi-homepage">

            <!-- Animated Background -->
            <div class="medi-bg-canvas">
                <div class="gradient-layer"></div>
                <div class="orb"></div>
                <div class="orb"></div>
                <div class="orb"></div>
            </div>
            <div class="medi-hero-img"></div>

            <!-- Navigation Bar -->
            <nav class="medi-nav">
                <a href="/" class="logo">
                    <svg viewBox="0 0 36 36" fill="none" width="36" height="36">
                        <rect x="2" y="2" width="32" height="32" rx="8" fill="url(#logoGrad)"/>
                        <path d="M18 10v16M10 18h16" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
                        <defs><linearGradient id="logoGrad" x1="2" y1="2" x2="34" y2="34">
                            <stop stop-color="#0ea5e9"/><stop offset="1" stop-color="#06d6a0"/>
                        </linearGradient></defs>
                    </svg>
                    MediSite Clinic
                </a>
                <div class="nav-links">
                    <a href="#features">Features</a>
                    <a href="#about">About</a>
                    <a href="#support">Support</a>
                    <button id="themeToggle" class="theme-toggle" title="Toggle dark mode">
                        <span class="toggle-knob">🌙</span>
                    </button>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="medi-main">
                <div class="medi-content">

                    <!-- Left: Hero Section -->
                    <div class="medi-hero">
                        <div class="badge">
                            <span class="pulse-dot"></span>
                            Hospital Pharmacy System
                        </div>
                        <h1>
                            Smart Healthcare<br/>
                            <span class="gradient-text">Management System</span>
                        </h1>
                        <p>
                            Streamline your clinical workflows with our integrated pharmacy,
                            patient management, and prescription system — built for modern
                            healthcare practitioners.
                        </p>
                        <div class="medi-features">
                            <div class="feature-item">
                                <div class="icon">💊</div>
                                <span>Pharmacy &amp; Drug Inventory Management</span>
                            </div>
                            <div class="feature-item">
                                <div class="icon">🩺</div>
                                <span>Patient Consultation &amp; Records</span>
                            </div>
                            <div class="feature-item">
                                <div class="icon">📋</div>
                                <span>Prescription &amp; Dispensing Workflow</span>
                            </div>
                            <div class="feature-item">
                                <div class="icon">📊</div>
                                <span>Clinical Reports &amp; Analytics</span>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Login Card -->
                    <div class="medi-login-card">
                        <div class="card-header">
                            <div class="lock-icon">🔐</div>
                            <h2>Welcome Back</h2>
                            <p>Sign in to access your dashboard</p>
                        </div>

                        <!-- Error Message -->
                        <t t-if="error">
                            <div class="login-error-msg" style="color:#ef4444;font-size:0.85rem;text-align:center;margin-bottom:14px;font-weight:600;padding:10px;background:rgba(239,68,68,0.1);border-radius:10px;border:1px solid rgba(239,68,68,0.2);">
                                <t t-esc="error"/>
                            </div>
                        </t>

                        <form action="/web/login" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="redirect" t-att-value="redirect"/>
                            <input type="hidden" name="type" value="password"/>

                            <div class="form-group">
                                <label for="login">Username</label>
                                <div class="input-wrap">
                                    <input type="text" id="login" name="login"
                                           t-att-value="login or ''"
                                           placeholder="Enter your username" required="required"
                                           autocomplete="username" autofocus="autofocus"/>
                                    <span class="input-icon">👤</span>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="password">Password</label>
                                <div class="input-wrap">
                                    <input type="password" id="password" name="password"
                                           placeholder="Enter your password" required="required"
                                           autocomplete="current-password"/>
                                    <span class="input-icon">🔑</span>
                                    <span id="pwToggle" style="position:absolute;right:14px;top:50%;transform:translateY(-50%);cursor:pointer;font-size:16px;opacity:0.5;">👁️</span>
                                </div>
                            </div>

                            <div class="form-options">
                                <label>
                                    <input type="checkbox" name="remember" style="accent-color:var(--primary);"/>
                                    Remember me
                                </label>
                                <a href="/web/reset_password">Forgot password?</a>
                            </div>

                            <button type="submit" class="btn-login">
                                <span class="btn-shine"></span>
                                Sign In
                            </button>
                        </form>

                        <div class="divider">Secure Access</div>
                        <div class="card-footer">
                            Protected with 256-bit encryption 🔒
                        </div>
                    </div>
                </div>
            </main>

            <!-- Footer -->
            <footer class="medi-footer">
                © 2026 MediSite Clinic &amp; Pharmacy System — All Rights Reserved
            </footer>

            <script src="/medisite_clinic/static/src/js/homepage.js"></script>
        </body>
        </html>
    </template>

</odoo>
