<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================
         IPD FORM
    ============================ -->
    <record id="view_med_ipd_form" model="ir.ui.view">
        <field name="name">med.ipd.form</field>
        <field name="model">med.ipd</field>
        <field name="arch" type="xml">
            <form string="IPD Admission" class="o_med_ipd_redesign">
                <header>
                    <button string="Admit Patient" type="object" name="action_admit" invisible="state != 'draft'" class="btn-primary fw-bold px-4 py-2 rounded-3" style="box-shadow: 0 2px 4px rgba(11, 92, 255, 0.2);"/>
                    <button string="Discharge Patient" type="object" name="action_discharge" invisible="state != 'admitted'" class="btn-success fw-bold px-4 py-2 rounded-3"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,admitted,discharged"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_patient" type="object" class="oe_stat_button" icon="fa-user">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Patient Profile</span>
                            </div>
                        </button>
                    </div>

                    <div class="row">
                        <!-- LEFT COLUMN: Main Form & Tabs -->
                        <div class="col-md-8">
                            <!-- General Information Card -->
                            <div class="card med_ipd_main_card border-0 shadow-sm mb-4">
                                <div class="card-body p-4">
                                    <h4 class="mb-4 d-flex align-items-center fw-bold text-dark" style="font-size: 1.25rem;">
                                        <i class="fa fa-plus-square text-primary me-2 fs-5"></i> General Information
                                    </h4>
                                    
                                    <div class="row g-4">
                                        <div class="col-md-6">
                                            <label for="patient_id" class="fw-bold small text-muted mb-2 d-block">Patient Name</label>
                                            <div class="d-flex align-items-center">
                                                <field name="priority" widget="priority" class="me-2"/>
                                                <field name="patient_id" placeholder="Select Patient..." class="fs-5 fw-bold text-dark w-100"/>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="name" class="fw-bold small text-muted mb-2 d-block">IPD Reference</label>
                                            <field name="name" class="fs-5 fw-bold text-dark w-100"/>
                                        </div>
                                        
                                        <div class="col-md-4">
                                            <label for="room_number" class="fw-bold small text-muted mb-2 d-block">Room Number</label>
                                            <field name="room_number" placeholder="Ward A, Room 101" class="fw-bold w-100"/>
                                        </div>
                                        <div class="col-md-4">
                                            <label for="bed_number" class="fw-bold small text-muted mb-2 d-block">Bed Number</label>
                                            <field name="bed_number" placeholder="Bed 01" class="fw-bold w-100"/>
                                        </div>
                                        <div class="col-md-4">
                                            <label for="consultation_id" class="fw-bold small text-muted mb-2 d-block">Related Consultation</label>
                                            <field name="consultation_id" class="fw-bold w-100"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Tabs Notebook -->
                            <div class="card border-0 shadow-sm bg-white">
                                <notebook class="med_ipd_notebook h-100">
                                    <page string="Clinical Context">
                                        <div class="row">
                                            <div class="col-12 mb-4">
                                                <label for="reason" class="fw-bold small text-muted mb-2 d-block">Reason for Admission / Principal Diagnosis</label>
                                                <field name="reason" placeholder="Principal diagnosis or reason..." class="fs-5 fw-bold text-primary w-100"/>
                                            </div>
                                            <div class="col-12">
                                                <label for="notes" class="fw-bold small text-muted mb-2 d-block">Additional Notes</label>
                                                <field name="notes" placeholder="Any additional notes..." class="w-100"/>
                                            </div>
                                        </div>
                                    </page>
                                    
                                    <page string="Nurse Progress Notes" name="nurse_notes">
                                        <field name="note_ids" nolabel="1" class="med_ipd_list_redesign">
                                            <list editable="bottom">
                                                <field name="date" class="fw-bold"/>
                                                <field name="nurse_id"/>
                                                <field name="note"/>
                                            </list>
                                        </field>
                                    </page>
                                    
                                    <page string="Doctor Ward Rounds" name="ward_rounds">
                                        <field name="round_ids" nolabel="1" class="med_ipd_list_redesign">
                                            <list editable="bottom">
                                                <field name="date" class="fw-bold"/>
                                                <field name="doctor_id"/>
                                                <field name="assessment"/>
                                                <field name="plan"/>
                                                <field name="instructions"/>
                                            </list>
                                        </field>
                                    </page>
                                </notebook>
                            </div>
                        </div>

                        <!-- RIGHT COLUMN: Summary Cards -->
                        <div class="col-md-4">
                            <!-- Admission Status Card -->
                            <div class="card border-0 shadow-sm rounded-3 mb-4 p-4 bg-white">
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <span class="fw-bold text-uppercase" style="font-size: 0.8rem; letter-spacing: 1px; color: #475569;">Admission Status</span>
                                    <!-- Dynamic badge based on state -->
                                    <span class="d-flex align-items-center fw-bold" style="font-size: 0.8rem; color: #059669;">
                                        <i class="fa fa-circle me-1" style="font-size: 0.5rem;"></i> <field name="state" nolabel="1" readonly="1" class="text-capitalize"/>
                                    </span>
                                </div>
                                
                                <div class="border rounded-3 p-4 mb-3 text-center shadow-sm" style="background-color: #ffffff; border-color: #f1f5f9 !important;">
                                    <div class="text-muted fw-bold mb-2" style="font-size: 0.85rem;">Stay Duration</div>
                                    <div class="d-flex align-items-baseline justify-content-center">
                                        <span class="fw-bolder text-dark lh-1" style="font-size: 3rem; letter-spacing: -1px;"><field name="stay_duration" nolabel="1" readonly="1" placeholder="0"/></span>
                                        <span class="ms-2 text-muted fw-bold" style="font-size: 1rem;">Days</span>
                                    </div>
                                </div>
                                
                                <div class="rounded-3 p-4 mb-3 text-white shadow-sm" style="background-color: #0b5cff;">
                                    <div style="font-size: 0.85rem; opacity: 0.9;" class="mb-2 fw-bold">Clinical Severity</div>
                                    <div class="fs-2 fw-bold d-flex align-items-center justify-content-between">
                                        <span><field name="clinical_severity" nolabel="1" readonly="1"/></span>
                                        <i class="fa fa-heartbeat" style="opacity: 0.5;"></i>
                                    </div>
                                    <div style="font-size: 0.75rem; opacity: 0.8;" class="mt-1">per latest assessment</div>
                                </div>

                                <div class="rounded-3 p-4 shadow-sm" style="background-color: #d1fae5; border: 1px solid #a7f3d0;">
                                    <div style="color: #065f46; font-size: 0.85rem;" class="mb-3 fw-bold text-capitalize">Admission Timeline</div>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span style="color: #047857; font-size: 0.9rem;" class="fw-bold">Admitted</span>
                                        <span style="color: #065f46; font-size: 1.1rem;" class="fw-bolder"><field name="admission_date" nolabel="1" readonly="1" widget="date"/></span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span style="color: #047857; font-size: 0.9rem;" class="fw-bold">Discharged</span>
                                        <span style="color: #065f46; font-size: 1.1rem;" class="fw-bolder"><field name="discharge_date" nolabel="1" readonly="1" widget="date" placeholder="Pending"/></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Ward Allocation Card -->
                            <div class="card border-0 shadow-sm rounded-3 overflow-hidden position-relative" style="height: 150px; background: linear-gradient(to bottom, #94a3b8, #475569);">
                                <div class="position-absolute w-100 h-100" style="background: linear-gradient(to top, rgba(0,0,0,0.8), rgba(0,0,0,0.1)); z-index: 1;"></div>
                                <div class="position-absolute bottom-0 start-0 p-4 w-100" style="z-index: 2;">
                                    <div class="text-white fw-bold text-uppercase mb-1" style="font-size: 0.75rem; letter-spacing: 1px; opacity: 0.8;">Ward Allocation</div>
                                    <div class="text-white fw-bolder fs-4"><field name="room_number" nolabel="1" readonly="1" placeholder="Unassigned Ward"/></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Chatter inside sheet forces bottom layout and full width -->
                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================
         IPD TREE
    ============================ -->
    <record id="view_med_ipd_tree" model="ir.ui.view">
        <field name="name">med.ipd.tree</field>
        <field name="model">med.ipd</field>
        <field name="arch" type="xml">
            <list string="IPD Admissions">
                <field name="priority" widget="priority" nolabel="1"/>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="admission_date"/>
                <field name="clinical_severity" widget="badge" decoration-success="clinical_severity == 'stable'" decoration-warning="clinical_severity == 'serious'" decoration-danger="clinical_severity == 'critical'"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-primary="state == 'admitted'" decoration-success="state == 'discharged'"/>
            </list>
        </field>
    </record>

    <record id="view_med_ipd_kanban" model="ir.ui.view">
        <field name="name">med.ipd.kanban</field>
        <field name="model">med.ipd</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column med_ipd_kanban">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="room_number"/>
                <field name="bed_number"/>
                <field name="admission_date"/>
                <field name="state"/>
                <field name="stay_duration"/>
                <field name="reason"/>
                <field name="clinical_severity"/>
                <field name="priority"/>

                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click med_ipd_card state_#{record.state.raw_value} severity_#{record.clinical_severity.raw_value}">
                            <div class="d-flex gap-3">
                                <div class="o_kanban_image flex-shrink-0">
                                    <img t-if="record.patient_id.raw_value"
                                         t-att-src="'/web/image/med.patient/' + record.patient_id.raw_value + '/photo'"
                                         alt="Patient Photo" class="o_image_64_max rounded-circle mt-1 mb-1"/>
                                    <img t-else=""
                                         src="/web/static/img/placeholder.png"
                                         alt="Avatar" class="o_image_64_max rounded-circle mt-1 mb-1"/>
                                </div>
                                <div class="oe_kanban_details flex-grow-1">
                                    <div class="med_ipd_header">
                                        <div class="med_header_main">
                                            <field name="priority" widget="priority"/>
                                            <span class="med_patient_name"><field name="patient_id"/></span>
                                        </div>
                                        <span class="med_ipd_ref"><field name="name"/></span>
                                    </div>
                                    <div class="med_ipd_body">
                                        <div class="med_ipd_info_row mt-1">
                                            <i class="fa fa-bed me-1" title="Bed Location"/>
                                            <span class="text-muted">Room <strong><field name="room_number"/></strong>, Bed <strong><field name="bed_number"/></strong></span>
                                        </div>
                                        <div class="med_ipd_badge_row">
                                             <span t-attf-class="badge rounded-pill severity_badge severity_#{record.clinical_severity.raw_value}">
                                                 <t t-esc="record.clinical_severity.value"/>
                                             </span>
                                        </div>
                                    </div>
                                    <div class="med_ipd_footer mt-2 d-flex justify-content-between align-items-center">
                                        <div class="med_stay_badge">
                                            <i class="fa fa-clock-o me-1" title="Stay Duration"/> <field name="stay_duration"/>
                                        </div>
                                        <div class="med_date text-muted small">
                                            <i class="fa fa-calendar me-1" title="Admission Date"/>
                                            <field name="admission_date" widget="date"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


</odoo>
